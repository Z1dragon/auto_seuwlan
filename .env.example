# Copy this file to .env and fill in your own account.
# Never commit or share your real .env file.

SEUWLAN_USERNAME=your_student_id
SEUWLAN_PASSWORD=your_password

# Windows Wi-Fi profile name. Usually the SSID is also the profile name.
SEUWLAN_WIFI_PROFILE=SEU-WLAN
SEUWLAN_WIFI_WAIT=5

# Optional. Leave blank to use captive-portal redirect auto-detection.
# Example shape only: https://w.seu.edu.cn/a79.htm?UserIP=10.x.x.x&wlanacname=...
SEUWLAN_LOGIN_URL=
SEUWLAN_MARKDOWN=seuwlan.local.md

# Empty means campus network. Use c/cmcc, t/telecom, u/unicom for ISP accounts.
SEUWLAN_ISP=

# The SEU ePortal scripts usually accept this placeholder.
SEUWLAN_MAC=000000000000

SEUWLAN_INTERVAL=60
SEUWLAN_TIMEOUT=5
SEUWLAN_CHECK_URLS=http://www.msftconnecttest.com/connecttest.txt,http://1.1.1.1,http://www.baidu.com/

# Keep this disabled for VPN/proxy scenarios. Captive portal auth must go directly
# to the campus network gateway, not through a system proxy.
SEUWLAN_USE_SYSTEM_PROXY=0

# Optional log file. install_task.ps1 passes logs\auto_seuwlan.log by default.
SEUWLAN_LOG_FILE=

# Advanced ePortal parameters. Do not change unless you know the campus portal needs it.
SEUWLAN_CALLBACK=dr1003
SEUWLAN_JS_VERSION=3.3.3
